generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id        String   @id @default(uuid())
  roomId    String   @unique // the human-facing room code (e.g. "abc-123")
  code      String   @default("") // last known editor contents
  language  String   @default("javascript")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // auto-bumped on every save
}
